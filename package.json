{
  "name": "hilihili-player",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter @hilihili/web --filter @hilihili/api --filter @hilihili/worker dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:push": "pnpm --filter @hilihili/db db:push",
    "clean": "pnpm -r clean"
  }
}
