HILI_API_HOST=0.0.0.0
HILI_API_PORT=4141
HILI_DATA_DIR=./app-data
HILI_SCAN_INTERVAL_MS=900000
HILI_FFMPEG_PATH=
HILI_FFPROBE_PATH=
# 安全演示模式由 pnpm dev:safe 自动配置：
# HILI_TEST_MODE=1
# HILI_ALLOWED_MEDIA_ROOT=./.hilihili-safe-demo/safe-demo-library
# 服务端渲染时访问 API 的地址；浏览器端会自动从当前页面 host 推导
# Docker 部署时通常使用 compose 服务名：http://api:4141
API_BASE_URL=http://localhost:4141
